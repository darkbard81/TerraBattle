{
  "name": "terrabattle",
  "version": "1.0.0",
  "description": "Grid-occupancy tactical battle prototype",
  "type": "module",
  "private": true,
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite",
    "editor": "vite --open /editor/",
    "build": "tsc -p tsconfig.typecheck.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darkbard81/TerraBattle.git"
  },
  "keywords": [
    "Terra",
    "Vite",
    "PixiJS"
  ],
  "author": "Slamon",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/darkbard81/TerraBattle/issues"
  },
  "homepage": "https://github.com/darkbard81/TerraBattle#readme",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@pixi/react": "^8.0.5",
    "pixi.js": "^8.17.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
