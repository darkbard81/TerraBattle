{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "terrabattle://schema/map.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "grid", "blocked_tiles", "spawns", "triggers"],
  "properties": {
    "id": { "$ref": "terrabattle://schema/common.schema.json#/$defs/Id" },
    "name": { "type": "string", "minLength": 1 },
    "grid": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "blocked_tiles": {
      "type": "array",
      "items": { "$ref": "terrabattle://schema/common.schema.json#/$defs/TileCoord" }
    },
    "spawns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["unit_id", "side", "x", "y"],
        "properties": {
          "unit_id": { "$ref": "terrabattle://schema/common.schema.json#/$defs/Id" },
          "side": { "type": "string", "enum": ["ally", "enemy"] },
          "x": { "type": "integer", "minimum": 0 },
          "y": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "event", "action"],
        "properties": {
          "id": { "$ref": "terrabattle://schema/common.schema.json#/$defs/Id" },
          "event": { "type": "string", "minLength": 1 },
          "action": { "type": "string", "minLength": 1 }
        }
      }
    },
    "extensions": { "type": "object" }
  }
}
